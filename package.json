{
	"name": "vytl-works-bv-website",
	"version": "0.0.1",
	"private": true,
	"description": "Main repository for the VYTL Works website.",
	"bugs": {
		"url": "https://github.com/vytlworks/website/issues"
	},
	"license": "Proprietary License",
	"author": "VYTL Works BV",
	"repository": {
		"type": "git",
		"url": "https://github.com/vytlworks/website.git"
	},
	"type": "module",
	"scripts": {
		"news:new": "npx tsx scripts/new-news.ts",
		"generate:news": "npx tsx scripts/generate-news.ts",
		"docs:build": "vitepress build",
		"docs:build:analyze": "vitepress build --analyze",
		"docs:dev": "vitepress dev",
		"docs:preview": "vitepress preview",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"lint:spell": "cspell --config ./cspell.yaml \"**/*.{ts,md,json,vue}\" --verbose",
		"prepare": "husky"
	},
	"devDependencies": {
		"@cspell/dict-vue": "^3.0.5",
		"@tsconfig/node24": "^24.0.4",
		"@types/node": "^25.5.0",
		"cspell": "^9.7.0",
		"husky": "^9.1.7",
		"oxfmt": "^0.43.0",
		"oxlint": "^1.58.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vitepress": "2.0.0-alpha.17",
		"vue": "^3.5.31"
	},
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}